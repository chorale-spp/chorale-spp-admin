rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()        { return request.auth != null; }
    function uid()           { return request.auth.uid; }
    function myRole()        { return get(/databases/$(database)/documents/members/$(uid())).data.role; }
    function isDirector()    { return myRole() == 'music_director'; }
    function isSecretary()   { return myRole() == 'secretary'; }
    function isTreasurer()   { return myRole() == 'treasurer'; }
    function isArchivist()   { return myRole() == 'archivist'; }
    function isDiscipline()  { return myRole() in ['discipline_dir','discipline_vic']; }
    function isVoiceResp()   { return myRole() == 'voice_resp'; }
    function isMaestro()     { return myRole() == 'maestro'; }
    function isAdmin()       { return myRole() in ['music_director','secretary','treasurer','archivist','maestro','discipline_dir','discipline_vic','voice_resp']; }

    match /members/{memberId} {
      allow read: if isAuth();
      allow create, delete: if isAuth() && (isDirector() || isSecretary());
      allow update: if isAuth() && (isDirector() || isSecretary() || uid() == memberId);
    }

    match /attendance/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isDiscipline() || isVoiceResp());
    }

    match /performance/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isDiscipline() || isVoiceResp() || isMaestro());
    }

    match /contributions/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isTreasurer());
    }

    match /transactions/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isTreasurer());
    }

    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isSecretary());
    }

    // Scores metadata only — actual PDFs live in the GitHub repo
    match /scores/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isArchivist());
    }

    match /announcements/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && (isDirector() || isSecretary());
    }

    match /absences/{docId} {
      allow read: if isAuth() && (isAdmin() || resource.data.memberId == uid());
      allow create: if isAuth() && request.resource.data.memberId == uid();
      allow update, delete: if isAuth() && isAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isAuth() && (isDirector() || isSecretary());
    }
  }
}
